{
  "name": "borgeto-print-agent",
  "version": "1.0.0",
  "description": "Windows System Tray print spooler agent for Borgeto POS",
  "main": "dist/main.js",
  "author": "Borgeto",
  "license": "UNLICENSED",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/borgetodev/borgeto-print-agent-release.git"
  },
  "scripts": {
    "build": "tsc && node -e \"require('node:fs').cpSync('src/ui','dist/ui',{recursive:true})\"",
    "start": "npm run build && electron .",
    "dev": "tsc --watch & electron .",
    "pack:win": "npm run build && electron-builder --win --x64 --publish never",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "dotenv": "^16.4.7",
    "firebase": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "electron": "^35.0.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.2"
  },
  "build": {
    "appId": "com.borgeto.print-agent",
    "productName": "Borgeto Print Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/tray-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "artifactName": "Borgeto-Print-Agent-Setup-${version}.${ext}"
    }
  }
}
