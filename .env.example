# Firebase
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# borgeto-pos-win ile aynı isimlendirme de desteklenir:
# VITE_apiKey=...
# VITE_authDomain=...
# VITE_projectID=...
# VITE_storageBucket=...
# VITE_messagingSenderID=...
# VITE_appId=...

# İsteğe bağlı: Realtime Database
# FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
# FIREBASE_USE_REALTIME_DB=true

# Spool klasörü (varsayılan: C:\Windows\System32\spool\PRINTERS)
# SPOOL_DIR=

# Tarama aralığı (ms)
POLL_INTERVAL_MS=2000

# Aynı işi tekrar kaydetmeme süresi (ms)
DEDUP_TTL_MS=120000
